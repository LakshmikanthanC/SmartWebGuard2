# MongoDB Connection URI
# Use this format: mongodb://localhost:27017/ai_nids
# Or use MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/ai_nids
MONGODB_URI=mongodb://localhost:27017/ai_nids

# Server Port
PORT=4000

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000
AI_SCAN_TIMEOUT_MS=120000
AI_BATCH_TIMEOUT_MS=180000
SIM_COUNTRY_WEIGHTS=US:25,CN:15,RU:12,DE:8,BR:7,IN:6,KR:5,JP:4,GB:4,FR:3,UA:3,NL:2,RO:2,VN:2,IR:2
SIM_DEFAULT_COUNTRY=ZZ
SIM_MIN_MALICIOUS_RATE=0.18

# Optional GeoIP providers for dynamic country resolution in URL scan:
# GeoIPify: https://geo.ipify.org/
GEOIPIFY_API_KEY=your-geoipify-api-key
# IPGeolocation: https://ipgeolocation.io/
IPGEOLOCATION_API_KEY=your-ipgeolocation-api-key
# IPinfo: https://ipinfo.io/
IPINFO_TOKEN=

# Optional LLM provider for chatbot (OpenAI-compatible API)
# If OPENAI_API_KEY is not set, backend falls back to local heuristic replies.
OPENAI_API_KEY=your-openai-api-key-here
# OPENAI_BASE_URL defaults to https://api.openai.com/v1
OPENAI_BASE_URL=https://api.openai.com/v1
# Use any chat-capable model exposed by your provider
OPENAI_MODEL=gpt-4o-mini
# Max wait for provider response before fast fallback (ms)
OPENAI_CHAT_TIMEOUT_MS=10000
# Local fallback stream pacing in ms (lower = faster)
CHAT_FALLBACK_CHUNK_DELAY_MS=8
