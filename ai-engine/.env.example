# URL analyzer runtime
URL_FAST_SCAN_MODE=false
URL_EXTERNAL_API_TIMEOUT=4
URL_DEEP_SCAN_TIMEOUT=4
URL_DEEP_SCAN_MAX_BYTES=300000
URL_SUBPAGE_CRAWL_LIMIT=2
URL_SUBPAGE_CRAWL_TIMEOUT=2
URL_SUBPAGE_CRAWL_MAX_BYTES=120000

# Domain and keyword lists (comma-separated)
TRUSTED_DOMAINS=google.com,github.com,microsoft.com,apple.com
PHISHING_KEYWORDS=login,verify,secure,account,update,password
BRAND_NAMES=google,github,microsoft,apple,paypal,amazon,facebook
SUSPICIOUS_TLDS=.tk,.xyz,.top,.gq,.ml,.cf

# Core risk scoring controls
URL_INVALID_URL_RISK_POINTS=95
URL_TRUSTED_DOMAIN_BONUS=-20
URL_MULTI_PHISHING_KEYWORDS_THRESHOLD=3
URL_MISSING_SECURITY_HEADERS_THRESHOLD=4
URL_MISSING_SECURITY_HEADERS_RISK_POINTS=8
URL_PHISHING_PAGE_POSSIBLE_THRESHOLD=3
URL_PHISHING_PAGE_DETECTED_THRESHOLD=5
URL_PHISHING_PAGE_POSSIBLE_RISK_POINTS=12
URL_PHISHING_PAGE_DETECTED_RISK_POINTS=25

# Final risk level thresholds
URL_RISK_LEVEL_CRITICAL_MIN=70
URL_RISK_LEVEL_HIGH_MIN=50
URL_RISK_LEVEL_MEDIUM_MIN=30
URL_RISK_LEVEL_LOW_MIN=15

# Optional reputation APIs
VIRUSTOTAL_API_KEY=
GOOGLE_SAFE_BROWSING_API_KEY=
ABUSEIPDB_API_KEY=